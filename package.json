{
  "name": "@tontoko/openclaw-structured-workflow",
  "version": "0.9.0",
  "type": "module",
  "description": "Task-list driven workflow plugin for OpenClaw with owner-scoped tasklist tools, cache-safe active-workflow guidance, and TaskFlow-backed durability.",
  "license": "MIT",
  "repository": "https://github.com/tontoko/openclaw-structured-workflow",
  "keywords": [
    "openclaw",
    "plugin",
    "workflow",
    "taskflow",
    "ultrawork"
  ],
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.4.9",
      "pluginSdkVersion": "2026.4.9"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.49"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "ultracite": "^7.4.4"
  },
  "scripts": {
    "check": "npm run lint && npm run typecheck && npm test",
    "lint": "ultracite check .",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  }
}
